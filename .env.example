# AI Nav — Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to git.

# Anthropic API key (optional — falls back to heuristic categorization)
# Get yours at: https://console.anthropic.com
# CLAUDE_API_KEY=sk-ant-...
# Also supports: ANTHROPIC_API_KEY

# Custom API base URL (for proxies or compatible services)
# BASE_URL=https://api.anthropic.com
# Also supports: ANTHROPIC_BASE_URL

# Claude model to use for AI categorization
# MODEL=claude-haiku-4-5-20251001
# Also supports: ANTHROPIC_MODEL
